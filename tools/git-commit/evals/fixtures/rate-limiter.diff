+//! Integration tests exercising the rate limiter under concurrent load.
+
+use std::sync::Arc;
+use std::time::{Duration, Instant};
+
+use mylib::rate_limit::RateLimiter;
+use tokio::task::JoinSet;
+
+/// With a burst of 1 and a rate of 10/s, ten concurrent acquirers should take
+/// roughly nine intervals (~900ms) to all complete, never less than the first.
+#[tokio::test]
+async fn concurrent_acquirers_are_paced() {
+    let limiter = RateLimiter::new(10.0, 1.0);
+    let start = Instant::now();
+
+    let mut tasks = JoinSet::new();
+    for _ in 0..10 {
+        let limiter = limiter.clone();
+        tasks.spawn(async move {
+            limiter.acquire().await;
+        });
+    }
+    while let Some(res) = tasks.join_next().await {
+        res.expect("task panicked");
+    }
+
+    let elapsed = start.elapsed();
+    assert!(elapsed >= Duration::from_millis(800), "too fast: {elapsed:?}");
+    assert!(elapsed < Duration::from_millis(2000), "too slow: {elapsed:?}");
+}
+
+/// A shared limiter cloned across tasks must enforce a single global budget,
+/// not one bucket per clone.
+#[tokio::test]
+async fn clones_share_one_budget() {
+    let limiter = RateLimiter::new(1.0, 2.0);
+    let a = limiter.clone();
+    let b = limiter.clone();
+
+    assert!(a.try_acquire().await);
+    assert!(b.try_acquire().await);
+    // Budget of 2 is now spent across both clones.
+    assert!(!a.try_acquire().await);
+    assert!(!b.try_acquire().await);
+}
+
+/// After draining the bucket, waiting one refill interval frees exactly one slot.
+#[tokio::test]
+async fn refill_grants_one_slot_per_interval() {
+    let limiter = RateLimiter::new(20.0, 1.0);
+    assert!(limiter.try_acquire().await);
+    assert!(!limiter.try_acquire().await);
+
+    tokio::time::sleep(Duration::from_millis(60)).await;
+    assert!(limiter.try_acquire().await);
+}
+
+/// Sanity: the limiter is `Send + Sync` so it can cross task boundaries.
+#[test]
+fn limiter_is_send_sync() {
+    fn assert_send_sync<T: Send + Sync>() {}
+    assert_send_sync::<RateLimiter>();
+    assert_send_sync::<Arc<RateLimiter>>();
+}
